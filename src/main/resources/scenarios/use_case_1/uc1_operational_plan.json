        },
        "GV": {
          "LR": 1.0
        }
      }
    },
    "FV_PASS": {
      "description": "FV direkt; RV hält; GV direkt",
      "shares": {
        "FV": {
          "LR": 1.0
        },
        "RV": {
          "LMR": 1.0
        },
        "GV": {
          "LR": 1.0
        }
      }
    },
    "FV_STOP": {
      "description": "FV hält; RV hält; GV direkt",
      "shares": {
        "FV": {
          "LMR": 1.0
        },
        "RV": {
          "LMR": 1.0
        },
        "GV": {
          "LR": 1.0
        }
      }
    }
  },
  "modes": {
    "KM": {
      "description": "Kernnetz-Mischbetrieb (hohe Heterogenität). Mix aus haltendem/durchfahrendem FV, RV und GV. (Ref: Lausanne–Genf, Heitersberg)",
      "patterns": [
        "FV_PASS",
        "FV_STOP"
      ],
      "shares": {
        "FV": 0.4,
        "RV": 0.4,
        "GV": 0.2
      }
    },
    "R": {
      "description": "Restnetz-Mischverkehr (Worst-Case). Interaktion von haltendem Fernverkehr und durchfahrendem Güterverkehr bei hohen Geschwindigkeitsdifferenzen. (Ref: Lugano)",
      "patterns": [
        "FV_STOP"
      ],
      "shares": {
        "FV": 0.5,
        "GV": 0.5
      }
    },
    "M": {
      "description": "Metrobetrieb isoliert (S-Bahn Charakter). Reiner Regionalverkehr, gleichmässige Dynamik und hohe Frequenz. (Ref: S-Bahn Zürich)",
      "patterns": [
        "STANDARD"
      ],
      "shares": {
        "RV": 1.0
      }
    }
  }
