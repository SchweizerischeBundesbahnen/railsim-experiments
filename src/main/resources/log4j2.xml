<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <Console name="stdout" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{ISO8061} %5p %c{1}:%L %m%n"/>
            <Filters>
                <ThresholdFilter level="WARN" onMatch="DENY" onMismatch="ACCEPT"/>
            </Filters>
        </Console>
        <Console name="stderr" target="SYSTEM_ERR">
            <PatternLayout pattern="%d{ISO8061} %5p %c{1}:%L %m%n"/>
            <Filters>
                <ThresholdFilter level="WARN" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="stdout"/>
            <AppenderRef ref="stderr"/>
        </Root>

        <!-- set the log level of matsim-libs dynamically -->
        <Logger name="org.matsim" level="${sys:matsim.log.level:-INFO}" additivity="false">
            <AppenderRef ref="stdout"/>
            <AppenderRef ref="stderr"/>
        </Logger>
        <Logger name="ch.sbb.matsim" level="${sys:matsim.log.level:-INFO}" additivity="false">
            <AppenderRef ref="stdout"/>
            <AppenderRef ref="stderr"/>
        </Logger>

        <!-- project logger has fixed level -->
        <Logger name="org.matsim.project" level="INFO" additivity="false">
            <AppenderRef ref="stdout"/>
            <AppenderRef ref="stderr"/>
        </Logger>
    </Loggers>

</Configuration>